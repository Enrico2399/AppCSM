{
  "rules": {
    ".read": false,
    ".write": false,
    "votes": {
      ".read": true,
      ".write": "auth != null"
    },
    "logs": {
      ".write": true
    },
    "moodHistory": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "communityMessages": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$messageId": {
        ".validate": "newData.hasChildren(['userId', 'userName', 'moodKey', 'message', 'timestamp']) && newData.child('userId').val() == auth.uid"
      }
    }
  }
}
